# Optional — enables the passwordless account + cross-device sync.
# Until both are set, the Account UI is hidden and the app is fully local.
#
# Get both from your Supabase project's "Connect" panel (the client key may be
# labeled "publishable key" or legacy "anon key" — either works; data is
# protected by row-level security, not key secrecy).
#
# Dev: copy to .env.local (gitignored). Prod: Cloudflare Pages → your project →
# Settings → Environment variables, then retry the deployment.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Set to 1 ONLY after Google OAuth is configured (Google Cloud client +
# Supabase provider enabled) — shows the "Continue with Google" button.
VITE_AUTH_GOOGLE=
